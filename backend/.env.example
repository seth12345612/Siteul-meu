# Google OAuth Configuration
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# Administrator: același username ca în users.json; poți folosi doar Google dacă setezi ADMIN_SECRET.
ADMIN_USERNAME=
# Cheie lungă, aleatoare (ex. 32+ caractere). O introduci la „parolă admin” în site dacă nu ai parolă pe cont.
ADMIN_SECRET=

# Other configurations (if needed)
GOOGLE_TRANSLATE_API_KEY=your_translation_api_key_here
